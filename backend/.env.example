# ── Servidor ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Base de datos (opción A: una sola URL, típico en la nube) ──
# DATABASE_URL=postgres://usuario:clave@host:5432/museo_piedra_pintada

# ── Base de datos (opción B: piezas sueltas, típico en local) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=museo_piedra_pintada
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui

# ── Seguridad ─────────────────────────────────────────────
# Genera un secreto largo y aleatorio para producción:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-esto-en-produccion-por-un-secreto-largo
JWT_EXPIRES=24h

# ── CORS: orígenes del frontend permitidos (separados por coma) ──
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5500

# ── Supabase Storage (fotos) ──────────────────────────────
# Si NO se configuran, las fotos se guardan en backend/public/uploads (solo local).
# En Vercel el disco es de SOLO LECTURA: estas variables son OBLIGATORIAS en producción.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=fotos
